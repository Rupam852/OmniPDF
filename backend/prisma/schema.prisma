datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String            @id // Firebase UID
  email     String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  geminiKey EncryptedApiKey?
  files     UserFile[]
  logs      ToolUsageLog[]
  workflows Workflow[]
}

model EncryptedApiKey {
  id           String   @id @default(uuid())
  userId       String   @unique
  encryptedKey String   // The encrypted key value
  iv           String   // Initialization Vector (hex) for AES-GCM
  authTag      String   // Authentication Tag (hex) for AES-GCM
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFile {
  id         String            @id @default(uuid())
  userId     String
  fileName   String
  fileSize   Int
  mimeType   String
  storageUrl String            // S3/GCS download url
  source     FileSource        @default(UPLOAD)
  isDeleted  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum FileSource {
  UPLOAD
  GOOGLE_DRIVE
  DROPBOX
  PROCESSED
}

model ToolUsageLog {
  id             String      @id @default(uuid())
  userId         String?
  toolName       String      // e.g. MERGE_PDF, AI_SUMMARIZER, COMPRESS_PDF
  status         LogStatus   @default(PENDING)
  errorMessage   String?     // Error reason if failed
  processingTime Int?        // processing duration in milliseconds
  createdAt      DateTime    @default(now())
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum LogStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Workflow {
  id        String   @id @default(uuid())
  userId    String
  name      String
  steps     Json     // Array of workflow actions e.g. ["MERGE_PDF", "COMPRESS_PDF"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
